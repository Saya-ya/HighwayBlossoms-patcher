    # script/hwb_s14.rpy:48
    old "Continuing to Moab"
    new "Continuing to Moab"

    # script/hwb_s14.rpy:64
    old "Getting close to Moab"
    new "Getting close to Moab"

    # script/hwb_s14.rpy:185
    old "Waiting on Marina"
    new "Waiting on Marina"

    # script/hwb_s14.rpy:734
    old "Struggling through the meal"
    new "Struggling through the meal"

